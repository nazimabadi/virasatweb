<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ pageTitle or site.title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Lora:ital,wght@0,400;0,500;1,400&family=Source+Sans+3:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --black: #0d0b09;
      --dark: #141210;
      --dark-card: #1a1612;
      --gold: #c9973a;
      --gold-light: #e0b96a;
      --gold-dim: #7a5a22;
      --ivory: #f5efe4;
      --ivory-dim: #d4c9b8;
      --terracotta: #b85c3a;
      --emerald: #1a4a3a;
      --burgundy: #5a1e28;
      --text-muted: #8a7e6e;
      --border: rgba(201,151,58,0.15);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      background: var(--black);
      color: var(--ivory);
      font-family: 'Source Sans 3', sans-serif;
      font-weight: 300;
      overflow-x: hidden;
    }

    /* ─── NAV ─── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 3rem;
      background: linear-gradient(to bottom, rgba(13,11,9,0.95), transparent);
      backdrop-filter: blur(2px);
    }

    .nav-logo { display: flex; flex-direction: column; gap: 0; text-decoration: none; }
    .nav-logo .en {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.35rem; font-weight: 500;
      letter-spacing: 0.3em; color: var(--ivory);
    }
    .nav-logo .ur {
      font-size: 0.95rem; color: var(--gold);
      letter-spacing: 0.05em; line-height: 1; text-align: right;
    }

    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links a {
      font-size: 0.75rem; font-weight: 400;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--ivory-dim); text-decoration: none; transition: color 0.3s;
    }
    .nav-links a:hover { color: var(--gold); }

    .nav-cta {
      font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--gold); border: 1px solid var(--gold-dim);
      padding: 0.5rem 1.25rem; text-decoration: none; transition: all 0.3s;
    }
    .nav-cta:hover { background: var(--gold); color: var(--black); }

    /* ─── HERO ─── */
    .hero {
      min-height: 100vh;
      display: flex; flex-direction: column; justify-content: flex-end;
      padding: 0 3rem 5rem; position: relative; overflow: hidden;
    }

    .hero-bg {
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 60% 50% at 70% 40%, rgba(90,30,40,0.25) 0%, transparent 70%),
        radial-gradient(ellipse 40% 60% at 20% 70%, rgba(26,74,58,0.2) 0%, transparent 60%),
        linear-gradient(160deg, #0d0b09 0%, #1a1210 50%, #0d0b09 100%);
    }

    .hero-photo { position: absolute; inset: 0; overflow: hidden; z-index: 0; }
    .hero-photo img {
      width: 100%; height: 100%; object-fit: cover;
      object-position: center top; opacity: 0.35; display: block;
    }
    .hero-photo-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(13,11,9,0.95) 0%, rgba(13,11,9,0.6) 50%, rgba(13,11,9,0.4) 100%);
    }

    .hero-ring {
      position: absolute; top: 50%; right: 5%;
      transform: translateY(-55%);
      width: 580px; height: 580px; border-radius: 50%;
      border: 1px solid rgba(201,151,58,0.08); pointer-events: none;
    }
    .hero-ring::before {
      content: ''; position: absolute; inset: 30px; border-radius: 50%;
      border: 1px solid rgba(201,151,58,0.06);
    }
    .hero-ring::after {
      content: ''; position: absolute; inset: 80px; border-radius: 50%;
      border: 1px solid rgba(201,151,58,0.04);
    }

    .hero-content { position: relative; z-index: 2; max-width: 750px; }

    .hero-location {
      font-size: 0.8rem; letter-spacing: 0.1em; color: var(--ivory-dim);
      margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.4rem;
      animation: fadeUp 0.8s ease both; animation-delay: 0.1s; opacity: 0;
    }

    .hero-label {
      font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 1.5rem;
      display: flex; align-items: center; gap: 1rem;
    }
    .hero-label::before {
      content: ''; display: block; width: 40px; height: 1px; background: var(--gold-dim);
    }

    .hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3.5rem, 7vw, 6.5rem);
      font-weight: 300; line-height: 1.05;
      color: var(--ivory); margin-bottom: 0.5rem;
    }
    .hero h1 em { font-style: italic; color: var(--gold-light); }

    .hero-urdu {
      font-size: clamp(1.5rem, 3vw, 2.5rem);
      color: var(--gold-dim); margin-bottom: 2rem; letter-spacing: 0.05em;
    }

    .hero-tagline {
      font-family: 'Lora', serif; font-style: italic;
      font-size: 1.1rem; color: var(--ivory-dim);
      max-width: 480px; line-height: 1.7; margin-bottom: 3rem;
    }

    .hero-slogan {
      font-size: 0.7rem; letter-spacing: 0.3em;
      text-transform: uppercase; color: var(--text-muted);
    }
    .hero-slogan span { color: var(--gold-dim); margin: 0 0.5rem; }

    .hero-actions { display: flex; gap: 1.5rem; margin-top: 2.5rem; align-items: center; }

    .btn-primary {
      background: var(--gold); color: var(--black);
      text-decoration: none; padding: 0.85rem 2rem;
      font-size: 0.7rem; letter-spacing: 0.18em;
      text-transform: uppercase; font-weight: 500; transition: all 0.3s;
      border: none; cursor: pointer; font-family: 'Source Sans 3', sans-serif;
    }
    .btn-primary:hover { background: var(--gold-light); }

    .btn-ghost {
      color: var(--ivory-dim); text-decoration: none;
      font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase;
      border-bottom: 1px solid var(--gold-dim); padding-bottom: 2px; transition: all 0.3s;
    }
    .btn-ghost:hover { color: var(--gold); border-color: var(--gold); }

    /* ─── STATS ─── */
    .stats-strip {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      background: rgba(201,151,58,0.03);
    }
    @media (min-width: 901px) {
      .stats-strip { grid-template-columns: repeat(5, 1fr); }
    }

    .stat-item {
      padding: 2.5rem 3rem;
      border-right: 1px solid var(--border);
      text-align: center;
    }
    .stat-item:last-child { border-right: none; }

    .stat-link { text-decoration: none; transition: background 0.3s; position: relative; }
    .stat-link:hover { background: rgba(201,151,58,0.06); }
    .stat-link:hover .stat-number { color: var(--gold-light); }
    .stat-link:hover .stat-hint { opacity: 1; }

    .stat-number {
      font-family: 'Cormorant Garamond', serif;
      font-size: 3rem; font-weight: 300;
      color: var(--gold); line-height: 1; margin-bottom: 0.4rem;
    }
    .stat-label {
      font-size: 0.65rem; letter-spacing: 0.15em;
      text-transform: uppercase; color: var(--text-muted);
    }
    .stat-hint {
      font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--gold-dim); margin-top: 0.3rem;
      opacity: 0; transition: opacity 0.3s;
    }

    /* ─── SECTIONS ─── */
    section { padding: 7rem 3rem; }

    .section-label {
      font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 1rem;
      display: flex; align-items: center; gap: 1rem;
    }
    .section-label::after {
      content: ''; flex: 1; height: 1px;
      background: var(--border); max-width: 80px;
    }

    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.2rem, 4vw, 3.5rem);
      font-weight: 300; line-height: 1.15;
      color: var(--ivory); margin-bottom: 1.5rem;
    }
    .section-title em { font-style: italic; color: var(--gold-light); }

    /* ─── FEATURED VIDEO ─── */
    .featured-video {
      background: var(--dark);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .fv-grid {
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 4rem;
      align-items: center;
    }

    .fv-player {
      position: relative;
      aspect-ratio: 16/9;
      background: var(--dark-card);
      overflow: hidden;
      cursor: pointer;
      border: 1px solid var(--border);
    }
    .fv-player img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s; }
    .fv-player:hover img { transform: scale(1.03); }
    .fv-player iframe { width: 100%; height: 100%; border: 0; display: block; }

    .fv-play-btn {
      position: absolute; top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 72px; height: 72px; border-radius: 50%;
      background: rgba(13,11,9,0.75);
      border: 1px solid var(--gold);
      display: flex; align-items: center; justify-content: center;
      transition: all 0.3s; pointer-events: none;
    }
    .fv-player:hover .fv-play-btn { background: var(--gold); }
    .fv-play-btn::after {
      content: ''; display: block;
      border-left: 18px solid var(--gold);
      border-top: 11px solid transparent;
      border-bottom: 11px solid transparent;
      margin-left: 5px; transition: border-color 0.3s;
    }
    .fv-player:hover .fv-play-btn::after { border-left-color: var(--black); }

    .fv-date {
      font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--gold-dim); margin-bottom: 1rem;
    }
    .fv-desc {
      font-family: 'Lora', serif;
      font-size: 1rem; line-height: 1.8; color: var(--ivory-dim);
      margin-bottom: 2rem;
    }

    /* ─── VIDEOS PAGE GRID ─── */
    .videos-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      margin-top: 3rem;
    }

    .video-card { }
    .video-embed {
      position: relative; aspect-ratio: 16/9;
      background: var(--dark-card); overflow: hidden;
      cursor: pointer; border: 1px solid var(--border);
    }
    .video-embed img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s; }
    .video-embed:hover img { transform: scale(1.04); }
    .video-embed iframe { width: 100%; height: 100%; border: 0; display: block; }

    .video-play {
      position: absolute; top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 54px; height: 54px; border-radius: 50%;
      background: rgba(13,11,9,0.75);
      border: 1px solid var(--gold);
      display: flex; align-items: center; justify-content: center;
      transition: all 0.3s; pointer-events: none;
    }
    .video-embed:hover .video-play { background: var(--gold); }
    .video-play::after {
      content: ''; display: block;
      border-left: 13px solid var(--gold);
      border-top: 8px solid transparent;
      border-bottom: 8px solid transparent;
      margin-left: 4px; transition: border-color 0.3s;
    }
    .video-embed:hover .video-play::after { border-left-color: var(--black); }

    .video-meta { padding: 1.25rem 0.25rem; }
    .video-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.25rem; font-weight: 400; color: var(--ivory);
      margin-bottom: 0.3rem;
    }
    .video-date {
      font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--gold-dim); margin-bottom: 0.5rem;
    }
    .video-desc { font-size: 0.85rem; line-height: 1.7; color: var(--text-muted); }

    /* ─── ABOUT ─── */
    .about { background: var(--dark); }

    .about-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 6rem; align-items: start;
    }

    .about-body {
      font-family: 'Lora', serif;
      font-size: 1.05rem; line-height: 1.85;
      color: var(--ivory-dim); margin-bottom: 1.5rem;
    }

    .about-principles {
      display: flex; flex-direction: column; gap: 1rem;
      margin-top: 2.5rem; padding-top: 2.5rem;
      border-top: 1px solid var(--border);
    }
    .principle { display: flex; align-items: baseline; gap: 1rem; }
    .principle-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.8rem; color: var(--gold-dim); min-width: 20px;
    }
    .principle-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem; font-weight: 400;
      color: var(--ivory); letter-spacing: 0.05em;
    }

    .about-right { padding-top: 1rem; }

    .about-quote {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 1.6rem; font-weight: 300;
      line-height: 1.6; color: var(--ivory-dim);
      border-left: 2px solid var(--gold-dim);
      padding-left: 2rem; margin-bottom: 3rem;
    }

    .about-image-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
    }
    .about-img {
      background: var(--dark-card); overflow: hidden;
    }
    .about-img:first-child { grid-row: span 2; min-height: 340px; }
    .about-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .about-img.ratio-43 { aspect-ratio: 4/3; }

    /* ─── CONNECTIONS CTA ─── */
    .connections-cta {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      padding: 4rem 3rem;
      background: var(--dark);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      text-decoration: none;
      transition: background 0.3s;
      position: relative;
      overflow: hidden;
    }
    .connections-cta:hover { background: var(--dark-card); }
    .connections-cta:hover .cta-headline em { letter-spacing: 0.05em; }

    .cta-eyebrow {
      font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--gold-dim); margin-bottom: 1rem;
    }
    .cta-headline {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 3.5vw, 3rem);
      font-weight: 300; line-height: 1.15; color: var(--ivory);
    }
    .cta-headline em {
      font-style: normal; color: var(--gold);
      display: inline-block; transition: letter-spacing 0.3s;
    }

    .cta-right { display: flex; justify-content: center; align-items: center; }
    .cta-web {
      position: relative; width: 220px; height: 160px;
      opacity: 0.6; transition: opacity 0.3s;
    }
    .connections-cta:hover .cta-web { opacity: 1; }
    .cta-lines { position: absolute; inset: 0; width: 100%; height: 100%; }
    .cta-node {
      position: absolute;
      font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--text-muted); white-space: nowrap;
    }
    .cta-node-centre {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1rem; color: var(--gold);
      top: 50%; left: 50%; transform: translate(-50%, -50%);
      letter-spacing: 0.05em;
    }
    .cta-node-tl { top: 6px; left: 10px; }
    .cta-node-tr { top: 6px; right: 10px; }
    .cta-node-bl { bottom: 6px; left: 10px; }
    .cta-node-br { bottom: 6px; right: 10px; }

    /* ─── PROGRAMS ─── */
    .programs-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 1.5px; margin-top: 4rem; background: var(--border);
    }
    .program-card {
      background: var(--dark); padding: 3rem 2.5rem;
      position: relative; overflow: hidden; cursor: default;
      transition: background 0.4s;
    }
    .program-card:hover { background: var(--dark-card); }
    .program-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: var(--gold-dim);
      transform: scaleX(0); transform-origin: left; transition: transform 0.4s;
    }
    .program-card:hover::before { transform: scaleX(1); }

    .program-icon { font-size: 1.8rem; margin-bottom: 1.5rem; display: block; }
    .program-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem; font-weight: 400;
      color: var(--ivory); margin-bottom: 1rem;
    }
    .program-desc { font-size: 0.9rem; line-height: 1.8; color: var(--text-muted); }
    .program-events {
      margin-top: 2rem; padding-top: 1.5rem;
      border-top: 1px solid var(--border);
    }
    .program-events-label {
      font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--gold-dim); margin-bottom: 0.75rem;
    }
    .event-tag {
      display: inline-block; font-size: 0.75rem; color: var(--ivory-dim);
      border: 1px solid var(--border); padding: 0.25rem 0.75rem;
      margin: 0.2rem 0.2rem 0.2rem 0; transition: all 0.3s;
    }
    .event-tag:hover { border-color: var(--gold-dim); color: var(--gold); }

    /* ─── EVENTS THUMBS ─── */
    .events-header {
      display: grid; grid-template-columns: 1fr auto;
      align-items: end; margin-bottom: 3rem;
    }

    .events-thumbs {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      margin-top: 2.5rem;
    }
    .event-thumb { position: relative; }
    .event-thumb-img {
      position: relative; aspect-ratio: 4/3;
      overflow: hidden; background: var(--dark-card);
    }
    .event-thumb-img img {
      width: 100%; height: 100%; object-fit: cover; display: block;
      transition: transform 0.5s ease;
    }
    .event-thumb:hover .event-thumb-img img { transform: scale(1.04); }
    .event-thumb-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(13,11,9,0.92) 0%, rgba(13,11,9,0.1) 60%, transparent 100%);
      padding: 1rem; display: flex; flex-direction: column; justify-content: flex-end;
    }
    .event-thumb-cat {
      font-size: 0.55rem; letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--gold-dim); margin-bottom: 0.2rem;
    }
    .event-thumb-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.95rem; font-weight: 400;
      color: var(--ivory); line-height: 1.3; margin-bottom: 0.2rem;
    }
    .event-thumb-date {
      font-size: 0.6rem; color: var(--text-muted); letter-spacing: 0.1em;
    }

    /* ─── MAILING + PARTNER ─── */
    .mailing {
      background: var(--emerald);
      position: relative; overflow: hidden;
    }
    .mailing::before {
      content: 'وراثت';
      position: absolute; right: -2rem; top: 50%;
      transform: translateY(-50%);
      font-size: 18rem; color: rgba(255,255,255,0.03);
      font-weight: 700; pointer-events: none; line-height: 1;
    }

    .mailing-dual {
      display: grid;
      grid-template-columns: 1fr 1px 1fr;
      gap: 4rem; align-items: start;
      position: relative; z-index: 1;
    }
    .mailing-divider { background: rgba(255,255,255,0.1); align-self: stretch; }

    .mailing-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 3.5vw, 3rem);
      font-weight: 300; color: var(--ivory);
      line-height: 1.2; margin-bottom: 1rem;
    }
    .mailing-sub {
      font-size: 0.95rem; line-height: 1.8;
      color: rgba(245,239,228,0.7);
    }

    .mailing-stats-row {
      display: flex; gap: 1.5rem; margin: 1.25rem 0;
      padding: 1rem 0;
      border-top: 1px solid rgba(255,255,255,0.08);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .mailing-stat { font-size: 0.8rem; color: rgba(245,239,228,0.5); }
    .mailing-stat span {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem; color: var(--gold); margin-right: 0.2rem;
    }

    .mailing-form { display: flex; flex-direction: column; gap: 1rem; margin-top: 1.5rem; }
    .path-select {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.15);
      color: var(--ivory); padding: 0.85rem 1.25rem;
      font-family: 'Source Sans 3', sans-serif; font-size: 0.85rem;
      width: 100%; appearance: none;
    }
    .path-select option { background: var(--emerald); }
    .form-row { display: flex; gap: 1rem; }
    .form-input {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.15);
      color: var(--ivory); padding: 0.85rem 1.25rem;
      font-family: 'Source Sans 3', sans-serif; font-size: 0.85rem;
      flex: 1; outline: none; transition: border-color 0.3s;
    }
    .form-input::placeholder { color: rgba(245,239,228,0.35); }
    .form-input:focus { border-color: var(--gold-dim); }
    .form-submit {
      background: var(--gold); color: var(--black); border: none;
      padding: 0.85rem 1.75rem;
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.7rem; letter-spacing: 0.15em;
      text-transform: uppercase; font-weight: 500;
      cursor: pointer; transition: background 0.3s; white-space: nowrap;
    }
    .form-submit:hover { background: var(--gold-light); }

    /* ─── TEAM ─── */
    .team { background: var(--dark); }
    .team-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      max-width: 800px;
      gap: 1.5px; background: var(--border); margin-top: 4rem;
    }
    .team-card { background: var(--dark); padding: 2.5rem 2rem; }
    .team-photo {
      width: 100%; aspect-ratio: 1;
      background: var(--dark-card);
      margin-bottom: 1.5rem; overflow: hidden;
    }
    .team-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .team-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem; font-weight: 500;
      color: var(--gold); margin-bottom: 0.25rem;
    }
    .team-role {
      font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--text-muted); margin-bottom: 1rem;
    }
    .team-bio { font-size: 0.85rem; line-height: 1.75; color: var(--text-muted); }

    /* ─── ARTISTS (renders only when artist entries exist) ─── */
    .artists { background: var(--dark); }
    .artists-grid {
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 1.5px; background: var(--border); margin-top: 3rem;
    }
    .artist-card { background: var(--dark); padding: 2rem 1.5rem; }
    .artist-photo {
      width: 100%; aspect-ratio: 3/4;
      background: var(--dark-card); margin-bottom: 1.25rem; overflow: hidden;
    }
    .artist-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .artist-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem; font-weight: 500;
      color: var(--gold); margin-bottom: 0.25rem;
    }
    .artist-role {
      font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--text-muted);
    }
    .artist-bio { font-size: 0.8rem; line-height: 1.7; color: var(--text-muted); margin-top: 0.75rem; }

    /* ─── PARTNERS ─── */
    .partners {
      padding: 4rem 3rem;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    .partners-inner { display: flex; align-items: center; gap: 3rem; }
    .partners-label {
      font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--text-muted); white-space: nowrap; min-width: 100px;
    }
    .partners-row { display: flex; gap: 3rem; flex-wrap: wrap; align-items: center; }
    .partner-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1rem; font-weight: 400;
      color: var(--ivory-dim); letter-spacing: 0.05em; transition: color 0.3s;
    }
    .partner-name:hover { color: var(--gold); }

    /* ─── CONNECT ─── */
    .connect { text-align: center; padding: 8rem 3rem; position: relative; }
    .connect-bg {
      position: absolute; inset: 0;
      background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(90,30,40,0.15) 0%, transparent 70%);
    }
    .connect-content { position: relative; z-index: 1; }
    .connect-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.5rem, 5vw, 4.5rem);
      font-weight: 300; color: var(--ivory);
      line-height: 1.15; margin-bottom: 1.5rem;
    }
    .connect-title em { font-style: italic; color: var(--gold-light); }
    .connect-sub {
      font-size: 1rem; color: var(--text-muted);
      max-width: 500px; margin: 0 auto 3rem; line-height: 1.8;
    }
    .connect-paths {
      display: flex; gap: 1px; background: var(--border);
      max-width: 800px; margin: 0 auto 3rem;
    }
    .connect-path {
      background: var(--dark); padding: 2rem 1.5rem; flex: 1;
      transition: background 0.3s; text-decoration: none; display: block;
    }
    .connect-path:hover { background: var(--dark-card); }
    .path-emoji { font-size: 1.5rem; margin-bottom: 0.75rem; display: block; }
    .path-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1rem; color: var(--gold); margin-bottom: 0.4rem;
    }
    .path-desc { font-size: 0.75rem; color: var(--text-muted); }
    .connect-contact { font-size: 0.8rem; color: var(--text-muted); letter-spacing: 0.05em; }
    .connect-contact a { color: var(--gold); text-decoration: none; }

    /* ─── FOOTER ─── */
    footer {
      padding: 3rem;
      border-top: 1px solid var(--border);
      display: grid; grid-template-columns: 1fr 1fr 1fr;
      align-items: center; gap: 2rem;
    }
    .footer-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem; letter-spacing: 0.25em; color: var(--ivory);
    }
    .footer-logo span { color: var(--gold); }
    .footer-links { display: flex; gap: 2rem; justify-content: center; }
    .footer-links a {
      font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--text-muted); text-decoration: none; transition: color 0.3s;
    }
    .footer-links a:hover { color: var(--gold); }
    .footer-right { text-align: right; font-size: 0.7rem; color: var(--text-muted); }
    .footer-social { display: flex; gap: 1.25rem; justify-content: flex-end; margin-bottom: 0.5rem; }
    .footer-social a {
      font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--text-muted); text-decoration: none; transition: color 0.3s;
    }
    .footer-social a:hover { color: var(--gold); }

    /* ─── ANIMATIONS ─── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .hero-label { animation: fadeUp 0.8s ease both; animation-delay: 0.2s; opacity: 0; }
    .hero h1 { animation: fadeUp 0.8s ease both; animation-delay: 0.4s; opacity: 0; }
    .hero-urdu { animation: fadeUp 0.8s ease both; animation-delay: 0.5s; opacity: 0; }
    .hero-tagline { animation: fadeUp 0.8s ease both; animation-delay: 0.6s; opacity: 0; }
    .hero-slogan { animation: fadeUp 0.8s ease both; animation-delay: 0.7s; opacity: 0; }
    .hero-actions { animation: fadeUp 0.8s ease both; animation-delay: 0.8s; opacity: 0; }

    /* ─── PAGE HERO (subpages) ─── */
    .page-hero { padding: 10rem 3rem 3rem; }
    .page-hero .section-title { margin-bottom: 0.5rem; }

    /* ─── MOBILE ─── */
    @media (max-width: 900px) {
      nav { padding: 1rem 1.5rem; }
      .nav-links { display: none; }
      section { padding: 5rem 1.5rem; }
      .hero { padding: 0 1.5rem 4rem; }
      .about-grid { grid-template-columns: 1fr; gap: 3rem; }
      .mailing-dual { grid-template-columns: 1fr; gap: 2.5rem; }
      .mailing-divider { display: none; }
      .programs-grid { grid-template-columns: 1fr 1fr; }
      .artists-grid { grid-template-columns: 1fr 1fr; }
      .team-grid { grid-template-columns: 1fr; max-width: 400px; margin-left: auto; margin-right: auto; }
      .events-thumbs { grid-template-columns: 1fr 1fr; }
      .videos-grid { grid-template-columns: 1fr; }
      .fv-grid { grid-template-columns: 1fr; gap: 2rem; }
      .stats-strip { grid-template-columns: 1fr 1fr; }
      .stat-item { border-right: none; border-bottom: 1px solid var(--border); }
      footer { grid-template-columns: 1fr; text-align: center; }
      .footer-links, .footer-social { justify-content: center; }
      .footer-right { text-align: center; }
      .connect-paths { flex-direction: column; }
      .partners-inner { flex-direction: column; align-items: flex-start; }
      .connections-cta { grid-template-columns: 1fr; gap: 2rem; padding: 3rem 1.5rem; }
      .cta-right { display: none; }
      .page-hero { padding: 8rem 1.5rem 2rem; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <a href="/" class="nav-logo">
      <span class="en">VIRASAT</span>
      <span class="ur">وراثت</span>
    </a>
    <ul class="nav-links">
      <li><a href="/#about">About</a></li>
      <li><a href="/#programs">Programs</a></li>
      <li><a href="/#events">Events</a></li>
      <li><a href="/videos/">Recordings</a></li>
      <li><a href="/#team">Team</a></li>
      <li><a href="/connections/">Our Story</a></li>
      <li><a href="/#connect">Connect</a></li>
    </ul>
    <a href="/#mailing" class="nav-cta">Stay Connected</a>
  </nav>

  {{ content | safe }}

  <!-- FOOTER -->
  <footer>
    <div>
      <div class="footer-logo">VIRASAT <span>وراثت</span></div>
      <div style="font-size: 0.65rem; color: var(--text-muted); margin-top: 0.4rem; letter-spacing: 0.05em;">Toronto · Est. 2020</div>
    </div>
    <div class="footer-links">
      <a href="/#about">About</a>
      <a href="/#programs">Programs</a>
      <a href="/#events">Events</a>
      <a href="/videos/">Recordings</a>
      <a href="/#connect">Connect</a>
    </div>
    <div class="footer-right">
      <div class="footer-social">
        <a href="{{ site.instagram_url }}" target="_blank" rel="noopener">Instagram</a>
        <a href="{{ site.youtube_url }}" target="_blank" rel="noopener">YouTube</a>
      </div>
      <div>© 2026 Virasat. All rights reserved.</div>
    </div>
  </footer>

  <script>
    // Netlify Identity redirect (required for CMS invite links to work)
    if (window.location.hash && window.location.hash.indexOf('invite_token') > -1) {
      var s = document.createElement('script');
      s.src = 'https://identity.netlify.com/v1/netlify-identity-widget.js';
      s.onload = function () {
        window.netlifyIdentity.on('init', function (user) {
          if (!user) {
            window.netlifyIdentity.on('login', function () {
              document.location.href = '/admin/';
            });
          }
        });
      };
      document.head.appendChild(s);
    }
  </script>
</body>
</html>
